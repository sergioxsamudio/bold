<div class="min-h-screen bg-gray-100 flex flex-col items-center p-4 space-y-4">

  <h1 class="text-xl font-bold text-gray-800 text-center">Estación 5</h1>

  <p class="text-lg font-medium text-gray-700 text-center">
    Selecciona el merchandising a redimir (máximo 3 artículos por participante)
  </p>

  <!-- Input para la cédula -->
  <div class="w-full max-w-sm">
    <label for="cedula" class="block text-sm font-medium text-gray-700 mb-1">Cédula del participante:</label>
    <input type="text" id="cedula" placeholder="Ingrese la cédula"
           class="w-full px-3 py-2 border rounded-md shadow-sm focus:ring-2 focus:ring-blue-500 focus:outline-none"
    />
  </div>

  <!-- Escáner QR -->
  <div class="w-full max-w-sm">
    <label class="block text-sm font-medium text-gray-700 mb-1">Escanea el QR del participante:</label>
    <div id="reader" class="rounded-lg border border-gray-300 shadow-sm"></div>
  </div>

  <!-- Mostrar saldo y redimidos -->
  <div class="w-full max-w-sm text-center hidden" id="infoUsuario">
    <p class="text-lg text-gray-800">
      Monto disponible: 
      <span id="montoDisponible" class="font-bold text-green-600">$0</span>
    </p>
    <p class="text-lg text-gray-800">
      Artículos redimidos: 
      <span id="articulosRedimidos" class="font-bold text-blue-600">Ninguno</span>
    </p>
    <p class="text-sm text-gray-500" id="articulosRestantes">
      Puedes seleccionar hasta 3 artículos.
    </p>
  </div>

  <!-- Selector de merchandising -->
  <div class="w-full max-w-sm space-y-2 hidden" id="merchSection">
    <label class="block text-sm font-medium text-gray-700 mb-1">Artículos disponibles:</label>
    <div id="merch" class="grid grid-cols-1 gap-2">
      <button data-item="Termo" data-price="20000"
              class="merch-btn w-full bg-white border border-gray-300 rounded-lg shadow-sm px-4 py-2 text-left hover:bg-blue-50">
        Termo - $20.000
      </button>
      <button data-item="Libreta" data-price="15000"
              class="merch-btn w-full bg-white border border-gray-300 rounded-lg shadow-sm px-4 py-2 text-left hover:bg-blue-50">
        Libreta - $15.000
      </button>
      <button data-item="Mug" data-price="10000"
              class="merch-btn w-full bg-white border border-gray-300 rounded-lg shadow-sm px-4 py-2 text-left hover:bg-blue-50">
        Mug - $10.000
      </button>
    </div>
  </div>

  <!-- Botón para redimir -->
  <button id="redimirBtn"
          class="w-full max-w-sm bg-green-600 text-white py-2 px-4 rounded-lg shadow-md disabled:opacity-50 hidden"
          disabled>
    Redimir selección
  </button>

</div>

<script src="https://unpkg.com/html5-qrcode"></script>
<script>
  let montoDisponible = 0;
  let redimidosPrevios = 0;
  let seleccionados = [];
  const maxTotal = 3;

  function actualizarUI() {
    document.getElementById('montoDisponible').textContent = montoDisponible.toLocaleString('es-CO', { style: 'currency', currency: 'COP' });
    document.getElementById('articulosRestantes').textContent =
      `Puedes seleccionar hasta ${maxTotal - redimidosPrevios} artículos.`;

    const button = document.getElementById('redimirBtn');
    button.disabled = seleccionados.length === 0;
  }

  // Al escanear QR correctamente
  function onScanSuccess(decodedText, decodedResult) {
    const cedula = document.getElementById('cedula').value.trim();
    if (cedula === "") {
      alert("Primero ingresa la cédula del participante.");
      return;
    }

    fetch(`/scans/buscar_participante?cedula=${cedula}&qr=${decodedText}`)
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          montoDisponible = data.monto_final;
          redimidosPrevios = data.redimidos_count;

          document.getElementById('montoDisponible').textContent = montoDisponible.toLocaleString('es-CO', { style: 'currency', currency: 'COP' });
          document.getElementById('articulosRedimidos').textContent = data.redimidos || "Ninguno";

          document.getElementById('infoUsuario').classList.remove('hidden');
          document.getElementById('merchSection').classList.remove('hidden');
          document.getElementById('redimirBtn').classList.remove('hidden');

          actualizarUI();
        } else {
          alert("Participante no encontrado.");
        }
      });
  }

  var html5QrcodeScanner = new Html5QrcodeScanner(
    "reader", { fps: 10, qrbox: { width: 250, height: 250 } });
  html5QrcodeScanner.render(onScanSuccess);

  // Manejar selección de artículos
  document.querySelectorAll('.merch-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const item = this.dataset.item;
      const price = parseInt(this.dataset.price);

      if (seleccionados.includes(item)) {
        seleccionados = seleccionados.filter(i => i !== item);
        montoDisponible += price;
        this.classList.remove('bg-blue-200');
      } else {
        if ((redimidosPrevios + seleccionados.length + 1) <= maxTotal && (montoDisponible - price) >= 0) {
          seleccionados.push(item);
          montoDisponible -= price;
          this.classList.add('bg-blue-200');
        } else {
          alert("Máximo 3 artículos en total o saldo insuficiente.");
        }
      }

      actualizarUI();
    });
  });

  document.getElementById('redimirBtn').addEventListener('click', function() {
    if (seleccionados.length === 0) {
      alert("Selecciona al menos un artículo para redimir.");
      return;
    }

    const cedula = document.getElementById('cedula').value.trim();

    fetch('/scans/redimir', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': "<%= form_authenticity_token %>"
      },
      body: JSON.stringify({
        cedula: cedula,
        redimidos: seleccionados,
        monto_final: montoDisponible
      })
    }).then(response => {
      if (response.ok) {
        alert("Redención exitosa. Nuevo saldo: $" + montoDisponible.toLocaleString('es-CO'));
        location.reload();
      } else {
        alert("Error al redimir.");
      }
    });
  });
</script>

